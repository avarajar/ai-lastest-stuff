# Anthropic API key (required for AI summarization)
ANTHROPIC_API_KEY=sk-ant-...

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Slack channel to post to (optional, overrides webhook default, e.g. #artificial-intelligence)
# SLACK_CHANNEL=#artificial-intelligence

# Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# GitHub personal access token (optional, increases rate limits)
GITHUB_TOKEN=ghp_...

# Reddit API credentials (optional, uses public JSON API by default)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# SQLite database path (default: ./ai-news.db)
# DB_PATH=./ai-news.db
